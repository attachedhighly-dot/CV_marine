5. CUDA Optical Flow (real-time motion)

#include <opencv2/cudaoptflow.hpp>
#include <opencv2/cudaimgproc.hpp>

int main() {
    cv::VideoCapture cap(0);
    cv::Mat frame, display;
    cv::cuda::GpuMat d_prev, d_curr, d_gray_prev,
                     d_gray_curr, d_flow;

    auto optflow = cv::cuda::FarnebackOpticalFlow::create();

    cap >> frame;
    d_prev.upload(frame);
    cv::cuda::cvtColor(d_prev, d_gray_prev, cv::COLOR_BGR2GRAY);

    while (true) {
        cap >> frame;
        if (frame.empty()) break;

        d_curr.upload(frame);
        cv::cuda::cvtColor(d_curr, d_gray_curr, cv::COLOR_BGR2GRAY);

        // GPU optical flow
        optflow->calc(d_gray_prev, d_gray_curr, d_flow);

        // Split into X/Y components and download
        cv::Mat flow;
        d_flow.download(flow);

        // Visualize magnitude
        std::vector<cv::Mat> channels(2);
        cv::split(flow, channels);
        cv::Mat magnitude, angle;
        cv::cartToPolar(channels[0], channels[1], magnitude, angle);
        cv::normalize(magnitude, display, 0, 255, cv::NORM_MINMAX);
        display.convertTo(display, CV_8U);

        cv::imshow("Optical Flow", display);

        d_gray_prev = d_gray_curr;
        if (cv::waitKey(1) == 'q') break;
    }
    return 0;
}